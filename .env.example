# Variables d'environnement — Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter le fichier .env

# ── APIs LLM ──────────────────────────────────────────────────
# Requis pour les pipelines level4_llm/ et family_D/D2_llm_assisted.py
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# ── Corpus OpenITI ────────────────────────────────────────────
# Chemin local vers le corpus OpenITI complet (non versionné)
OPENITI_CORPUS_PATH=/path/to/openiti/data

# ── Configuration optionnelle ─────────────────────────────────
# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
